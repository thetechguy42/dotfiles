#!/usr/bin/env bash
# Cleans up a waystt transcript (filler words, grammar, spoken numbers) via
# OpenAI before typing it at the cursor with wtype. Drop-in replacement for
# piping waystt's raw output straight to wtype.
set -euo pipefail

ENV_FILE="$HOME/.config/waystt/.env"
if [[ -f "$ENV_FILE" ]]; then
    set -a
    source "$ENV_FILE"
    set +a
fi

TRANSCRIPT="$(cat)"

if [[ -z "$TRANSCRIPT" ]]; then
    exit 0
fi

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
    echo "waystt-cleanup: OPENAI_API_KEY not set, passing through raw transcript" >&2
    printf '%s' "$TRANSCRIPT" | wtype -
    exit 0
fi

CLEANUP_MODEL="${WAYSTT_CLEANUP_MODEL:-gpt-4.1-mini}"

REQUEST_BODY="$(jq -n --arg model "$CLEANUP_MODEL" --arg transcript "$TRANSCRIPT" '{
    model: $model,
    temperature: 0.2,
    messages: [
        {role: "system", content: "You clean up raw voice-dictation transcripts. Remove filler words (um, uh, like), fix grammar and punctuation, and convert spoken numbers/dates into written form. Preserve the speaker'\''s meaning, tone, and intent exactly. Output only the cleaned text, nothing else -- no preamble, no quotes, no explanation."},
        {role: "user", content: $transcript}
    ]
}')"

RESPONSE="$(curl -sS --max-time 15 https://api.openai.com/v1/chat/completions \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$REQUEST_BODY" || true)"

CLEANED="$(jq -r '.choices[0].message.content // empty' <<<"$RESPONSE" 2>/dev/null || true)"

if [[ -z "$CLEANED" ]]; then
    echo "waystt-cleanup: cleanup failed, passing through raw transcript" >&2
    echo "$RESPONSE" >&2
    printf '%s' "$TRANSCRIPT" | wtype -
    exit 0
fi

printf '%s' "$CLEANED" | wtype -
